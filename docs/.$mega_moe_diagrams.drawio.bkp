        </mxCell>
        <mxCell id="tr6_3" value="同 (固定开销)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFE0B2;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="580" y="3350" width="220" height="22" as="geometry" />
