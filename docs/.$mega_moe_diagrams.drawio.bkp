        <mxCell id="smem_b" value="smem_b[0..kNumStages-1]&lt;br&gt;[LOAD_BLOCK_N × BLOCK_K × sizeof(FP4)]&lt;br&gt;(pipelined weight tiles)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#64B5F6;strokeColor=#1565C0;fontSize=10;fontColor=#FFF;" vertex="1" parent="smem_group">
