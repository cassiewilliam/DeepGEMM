        <mxCell id="remote_combine" value="&lt;b&gt;Combine Token Buffer&lt;/b&gt;&lt;br&gt;(BF16)&lt;br&gt;[num_topk, num_max_tokens, hidden×2B]&lt;br&gt;&lt;i&gt;L2 results written here via NVLink&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=10;" vertex="1" parent="remote_group">
