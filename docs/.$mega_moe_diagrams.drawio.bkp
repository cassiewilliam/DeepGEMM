        <mxCell id="local_group" value="Local HBM (Symmetric Memory Buffers)" style="swimlane;startSize=28;fillColor=#E8F5E9;strokeColor=#2E7D32;rounded=1;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="60" width="480" height="880" as="geometry" />
        </mxCell>
        <mxCell id="workspace" value="&lt;b&gt;Workspace&lt;/b&gt;&lt;br&gt;• Grid sync counters (4 × uint32)&lt;br&gt;• NVLink barrier counter + signals&lt;br&gt;• Expert send count (num_experts × uint64)&lt;br&gt;• Expert recv count (ranks × experts × uint64)&lt;br&gt;• Expert recv count sum (per-rank × uint64)&lt;br&gt;• L1 arrival count (pool_blocks × uint32)&lt;br&gt;• L2 arrival mask (pool_blocks × uint64)&lt;br&gt;• Src token_topk_idx (dispatch routing)&lt;br&gt;• TokenSrcMetadata (combine routing)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="local_group">
