        <mxCell id="smem_send" value="smem_send_buffers&lt;br&gt;[kNumDispatchWarps × hidden B]&lt;br&gt;(dispatch TMA pull staging)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;" vertex="1" parent="smem_group">
