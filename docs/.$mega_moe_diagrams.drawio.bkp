        <mxCell id="tr5_5" value="NVLink 拥塞时的真正瓶颈 — 需监控" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="1100" y="3328" width="1200" height="22" as="geometry" />
        </mxCell>
        <mxCell id="tr6_1" value="grid_sync / nvlink_barrier" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E1BEE7;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="100" y="3350" width="300" height="22" as="geometry" />
