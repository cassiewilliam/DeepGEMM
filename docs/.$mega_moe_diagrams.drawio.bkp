        <mxCell id="tr2_5" value="可忽略，BW-bound 下被 TMA 掩盖" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="1100" y="3262" width="1200" height="22" as="geometry" />
        </mxCell>
        <mxCell id="tr3_1" value="barrier.sync (unaligned, id 1)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="100" y="3284" width="300" height="22" as="geometry" />
        </mxCell>
        <mxCell id="tr3_2" value="~50 cyc" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="400" y="3284" width="180" height="22" as="geometry" />
        </mxCell>
        <mxCell id="tr3_3" value="~100 cyc" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="580" y="3284" width="220" height="22" as="geometry" />
        </mxCell>
        <mxCell id="tr3_4" value="3 次/kernel" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;fontSize=10;" parent="1" vertex="1">
