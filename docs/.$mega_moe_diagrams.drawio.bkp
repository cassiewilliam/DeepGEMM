        <mxCell id="s4_title" value="④ Block 级 Named Barrier 分配（16 个硬件槽位）" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=16;fontStyle=1;fontColor=#1A237E;" parent="1" vertex="1">
