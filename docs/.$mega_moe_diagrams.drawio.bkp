          <mxGeometry x="800" y="3350" width="300" height="22" as="geometry" />
        </mxCell>
        <mxCell id="tr6_5" value="对小 batch 是主要开销 (~25 μs 固定)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="1100" y="3350" width="1200" height="22" as="geometry" />
