        <mxCell id="tmem_accum" value="&lt;b&gt;Accumulator Columns&lt;/b&gt;&lt;br&gt;UMMA_N × kNumEpilogueStages (2)&lt;br&gt;= BLOCK_M × 2 columns&lt;br&gt;FP32, double-buffered" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#C62828;fontSize=10;" vertex="1" parent="tmem_group">
