        </mxCell>
        <mxCell id="smem_amax" value="smem_amax_reduction&lt;br&gt;[STORE_BM × num_epilogue_warps/2 × float2]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;" vertex="1" parent="smem_group">
